# API Server Environment Variables
# Copy this file to .env and fill in the values

PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# URL of the locally running frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgres://user:password@localhost:5432/cdsi

# AI providers used by the analysis pipeline
GROQ_API_KEY=
DXGPT_API_KEY=
DXGPT_ENDPOINT=
