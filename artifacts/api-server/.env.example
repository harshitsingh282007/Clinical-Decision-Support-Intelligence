# API Server Environment Variables
# Copy this file to .env and fill in the values

PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# URL of the locally running frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgres://user:password@localhost:5432/cdsi

# AI provider configuration (any OpenAI-compatible API works)
# Examples:
#   DeepSeek:  AI_BASE_URL=https://api.deepseek.com/v1  AI_MODEL=deepseek-v4-flash
#   OpenAI:    AI_BASE_URL=https://api.openai.com/v1     AI_MODEL=gpt-4o
#   Gemini:    AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  AI_MODEL=gemini-3.6-flash
#   Groq:      AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
#   Ollama:    AI_BASE_URL=http://localhost:11434/v1      AI_MODEL=llama3
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
